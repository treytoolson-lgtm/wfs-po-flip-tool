# ============================================================
# WFS Escalation + PO Flip Tool — Environment Config
# Copy this file to .env and fill in your values
# ============================================================

# GCloud SDK path — only needed if gcloud is NOT already on your PATH
# Mac example:    /Users/yourname/Documents/gCloud CLI/google-cloud-sdk
# Windows example: C:/Users/yourname/AppData/Local/Google/Cloud SDK/google-cloud-sdk
# Leave blank if gcloud was installed via official installer (already on PATH)
GCLOUD_SDK_PATH=

# BigQuery projects (don't change these)
BQ_PROJECT_PRIMARY=wmt-cp-prod
BQ_PROJECT_ANALYTICS=wmt-wfs-analytics

# SharePoint — PO Flip spreadsheet
SHAREPOINT_SITE=https://wal-mart.sharepoint.com/sites/FulfillmentServices
SHAREPOINT_FILE_ID=3412E7C8-7761-4233-B87D-384885821FEE
SHAREPOINT_SHEET=Sheet1

# Microsoft Teams — for flip approval notifications
# Get these from the Teams channel URL
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=

# App settings
APP_PORT=8766
WOS_THRESHOLD=2.0

# Scheduler — EST hours to poll SharePoint for updates (comma-separated)
MONITOR_SCHEDULE_HOURS=9,13,17